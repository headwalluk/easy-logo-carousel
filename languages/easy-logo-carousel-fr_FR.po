#: src/edit.js:54
msgid "Carousel settings"
msgstr "Paramètres du carrousel"

#: build/index.js:1
#: src/edit.js:57
msgid "Scroll speed (seconds per logo set)"
msgstr "Vitesse de défilement (en secondes par série de logos)"

#: build/index.js:1
#: src/edit.js:61
msgid "Lower is faster. This stays consistent however many times the set repeats."
msgstr "Plus la vitesse est faible, plus c'est rapide. Cela reste vrai quel que soit le nombre de répétitions de la série."

