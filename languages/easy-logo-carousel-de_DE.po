#. Plugin Name of the plugin
#: easy-logo-carousel.php
msgid "Easy Logo Carousel"
msgstr "Einfaches Logo-Karussell"

#. Plugin URI of the plugin
#. Author URI of the plugin
#: easy-logo-carousel.php
msgid "https://headwall-hosting.com/"
msgstr "https://headwall-hosting.com/"

#. Description of the plugin
#: easy-logo-carousel.php
msgid "A lightweight Gutenberg block for an auto-scrolling, continuously looping marquee of logo images from the Media Library. Pure CSS, no frontend JavaScript library."
msgstr "Ein schlanker Gutenberg-Block für einen automatisch scrollenden, endlos wiederholten Lauftext mit Logo-Bildern aus der Medienbibliothek. Reines CSS, keine JavaScript-Bibliothek im Frontend."

#. Author of the plugin
#: easy-logo-carousel.php
msgid "Paul Faulkner"
msgstr "Paul Faulkner"

