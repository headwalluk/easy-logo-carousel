#. Plugin Name of the plugin
#: easy-logo-carousel.php
msgid "Easy Logo Carousel"
msgstr "Carrusel de logotipos sencillo"

#. Plugin URI of the plugin
#. Author URI of the plugin
#: easy-logo-carousel.php
msgid "https://headwall-hosting.com/"
msgstr "https://headwall-hosting.com/"

#. Description of the plugin
#: easy-logo-carousel.php
msgid "A lightweight Gutenberg block for an auto-scrolling, continuously looping marquee of logo images from the Media Library. Pure CSS, no frontend JavaScript library."
msgstr "Un bloque Gutenberg ligero para crear un letrero con desplazamiento automático y reproducción en bucle continuo de imágenes de logotipos de la biblioteca multimedia. Puro CSS, sin bibliotecas de JavaScript para el front-end."

#. Author of the plugin
#: easy-logo-carousel.php
msgid "Paul Faulkner"
msgstr "Paul Faulkner"

#: build/index.js:1
#: src/edit.js:54
msgid "Carousel settings"
msgstr "Configuración del carrusel"

#: build/index.js:1
#: src/edit.js:57
msgid "Scroll speed (seconds per logo set)"
msgstr "Velocidad de desplazamiento (segundos por conjunto de logotipos)"

#: build/index.js:1
#: src/edit.js:61
msgid "Lower is faster. This stays consistent however many times the set repeats."
msgstr "Cuanto más bajo, más rápido. Esto se mantiene constante independientemente del número de repeticiones que se realice la serie."

#: build/index.js:1
#: src/edit.js:73
msgid "Pause on hover"
msgstr "Pausar al pasar el cursor por encima"

